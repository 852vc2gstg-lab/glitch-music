  useEffect(() => {
    if (!window.novaPlayer?.onMiniModeChange) {
      return undefined
    }

    return window.novaPlayer.onMiniModeChange((nextState) => {
      setIsMiniPlayerMode(Boolean(nextState))
      setMiniVolumeOpen(false)
      setDockPlaylistMenuOpen(false)
      setTrackMenuId(null)
      setPlaylistMenuTrackId(null)
      setPlaylistMenuPosition(null)
    })
  }, [])

  useEffect(() => {
    const syncMiniModeFromWindowSize = () => {
      const shouldUseMiniPlayer = window.innerWidth <= 500 && window.innerHeight <= 260

      setIsMiniPlayerMode((prev) => {
        if (prev === shouldUseMiniPlayer) {
          return prev
        }

        if (shouldUseMiniPlayer) {
          setMiniVolumeOpen(false)
          setDockPlaylistMenuOpen(false)
          setTrackMenuId(null)
          setPlaylistMenuTrackId(null)
          setPlaylistMenuPosition(null)
        }

        return shouldUseMiniPlayer
      })
    }

    syncMiniModeFromWindowSize()
    window.addEventListener('resize', syncMiniModeFromWindowSize)

    return () => {
      window.removeEventListener('resize', syncMiniModeFromWindowSize)
    }
  }, [])
  const updateAppSettings = (nextSettings) => {
