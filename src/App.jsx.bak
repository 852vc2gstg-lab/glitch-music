          <div className="mini-player-controls">
            <button className={`icon-button ${shuffleEnabled ? 'active' : ''}`} onClick={() => setShuffleEnabled((prev) => !prev)} aria-label="Kar???k ?al">
              <Shuffle size={18} />
            </button>
            <button className="icon-button" onClick={restartTrack} aria-label="Ba?a al">
