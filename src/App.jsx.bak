          <div className="mini-player-progress">
            <span className="time-badge time-badge--start">{formatTime(progress)}</span>
            <input
              className="range range-progress"
              type="range"
              min="0"
              max={duration || 0}
              step="0.1"
              value={Math.min(progress, duration || 0)}
