        artistFacts.formedAt ? `KuruluÃƒâ€¦Ã…Â¸: ${artistFacts.formedAt}` : '',
        artistFacts.birthDate ? `DoÃƒâ€Ã…Â¸um: ${artistFacts.birthDate}` : '',
        artistFacts.members?.length ? `ÃƒÆ’Ã…â€œyeler: ${artistFacts.members.join(', ')}` : '',
      ]
        .filter(Boolean)
        .join(' Ãƒâ€šÃ‚Â· ')
    : ''
  const totalDuration = useMemo(
    () => tracks.reduce((sum, track) => sum + (track.duration || 0), 0),
    [tracks],
  )

  const getNextTrack = () => {
    if (!visibleTracks.length) {
      return null
    }

    if (shuffleEnabled) {
      const pool = visibleTracks.filter((track) => track.id !== currentTrackId)
      const source = pool.length ? pool : visibleTracks
      return source[Math.floor(Math.random() * source.length)] || null
    }

    const activeIndex = visibleTracks.findIndex((track) => track.id === currentTrackId)
    const nextIndex = activeIndex >= 0 ? (activeIndex + 1) % visibleTracks.length : 0
    return visibleTracks[nextIndex] || null
  }

  const visibleTracks = useMemo(() => {
    if (selectedCollectionId === 'favorites') {
      return sortTracksByOrder(allTracks.filter((track) => track.isFavorite))
    }

      if (selectedCollectionId === 'server') {
        return sortTracksByOrder(serverTracks)
      }

    if (selectedCollectionId !== 'all') {
      const playlist = playlists.find((item) => item.id === selectedCollectionId)
      if (playlist) {
        return sortTracksByOrder(allTracks.filter((track) => playlist.trackIds.includes(track.id)))
      }
    }

    return sortTracksByOrder(tracks)
  }, [allTracks, playlists, selectedCollectionId, serverTracks, tracks])

  const updateTrack = (trackId, updates) => {
    setTracks((prev) =>
      prev.map((track) => (track.id === trackId ? { ...track, ...updates } : track)),
    )
  }

  const moveTrackUp = (trackId) => {
    setTracks((prev) => {
      const ordered = sortTracksByOrder(prev)
      const index = ordered.findIndex((track) => track.id === trackId)
      if (index <= 0) {
        return prev
      }

      const next = ordered.map((track) => ({ ...track }))
      const current = next[index]
      const previous = next[index - 1]
      const currentOrder = getTrackSortValue(current, index)
      const previousOrder = getTrackSortValue(previous, index - 1)

      next[index] = { ...current, order: previousOrder }
      next[index - 1] = { ...previous, order: currentOrder }
      return next
    })
  }

  const openEditor = (track) => {
    setEditTargetId(track.id)
    setEditDraft({ title: track.title, artist: track.artist })
